# Скопируйте в backend/.env (НЕ коммитьте .env в git!)
SECRET_KEY=change-me-in-production-use-long-random-string

# DeepSeek API
DEEPSEEK_API_KEY=your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DAILY_LLM_LIMIT=100

# Ключ для серверных вызовов агентов (создание задач от имени пользователя)
AGENT_API_KEY=change-me-agent-api-key
